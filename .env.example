# Copia este fichero a .env y ajusta valores. .env NUNCA se commitea (gitleaks vigila).

# PostgreSQL (compose y apps; POSTGRES_HOST=localhost porque las apps corren fuera de compose en F1)
POSTGRES_HOST=localhost
POSTGRES_USER=fenix
POSTGRES_PASSWORD=cambiame-en-local
POSTGRES_DB=fenix
POSTGRES_PORT=5432

# Ollama (compose)
OLLAMA_PORT=11434

# Dispositivo de embeddings/reranker (ADR-009): cpu (def.) | cuda | auto.
# El runner de evals usa auto por su cuenta; aquí solo si quieres forzarlo globalmente.
# FENIX_DEVICE=cpu

# F2+: clave gratuita de AI Studio
# GEMINI_API_KEY=
